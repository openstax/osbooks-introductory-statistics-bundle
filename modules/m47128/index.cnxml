</m:mrow>
</m:mfrac>

</m:mrow>
</m:math>
</equation>

<para id="eip-idp15158384">where <m:math><m:mi>n</m:mi></m:math><sub>1</sub> = 4, <m:math><m:mi>n</m:mi></m:math><sub>2</sub> = 3, <m:math><m:mi>n</m:mi></m:math><sub>3</sub> = 3  and  <m:math><m:mi>n</m:mi><m:mo>=</m:mo><m:mi>n</m:mi></m:math><sub>1</sub> + <m:math><m:mi>n</m:mi></m:math><sub>2</sub> + <m:math><m:mi>n</m:mi></m:math><sub>3</sub> = 10</para><equation class="unnumbered" id="fs-idp1558352"><label/><m:math>
