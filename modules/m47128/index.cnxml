</section> </content>
  <glossary>
    <definition id="f-distribution">
      <term>F Distribution</term>
      <meaning id="mean-f-distribution">the probability distribution used for ANOVA and for the test of two variances; it is right-skewed, takes only non-negative values, and is defined by two degrees of freedom, one for the numerator and one for the denominator.</meaning>
    </definition>
    <definition id="f-ratio">
      <term>F Ratio</term>
      <meaning id="mean-f-ratio">the test statistic for one-way ANOVA, <m:math><m:mi>F</m:mi><m:mo>=</m:mo><m:mfrac><m:mrow><m:msub><m:mtext>MS</m:mtext><m:mtext>between</m:mtext></m:msub></m:mrow><m:mrow><m:msub><m:mtext>MS</m:mtext><m:mtext>within</m:mtext></m:msub></m:mrow></m:mfrac></m:math>, the ratio of two independent estimates of the population variance.</meaning>
    </definition>
    <definition id="mean-square">
      <term>Mean Square</term>
      <meaning id="mean-mean-square">an estimate of variance found by dividing a sum of squares by its degrees of freedom; <m:math><m:msub><m:mtext>MS</m:mtext><m:mtext>between</m:mtext></m:msub></m:math> is the variance between groups and <m:math><m:msub><m:mtext>MS</m:mtext><m:mtext>within</m:mtext></m:msub></m:math> is the variance within groups.</meaning>
    </definition>
    <definition id="sum-of-squares">
      <term>Sum of Squares</term>
      <meaning id="mean-sum-of-squares">a measure of variation equal to a sum of squared deviations; <m:math><m:msub><m:mtext>SS</m:mtext><m:mtext>between</m:mtext></m:msub></m:math> represents the variation among the different samples and <m:math><m:msub><m:mtext>SS</m:mtext><m:mtext>within</m:mtext></m:msub></m:math> represents the variation within samples that is due to chance.</meaning>
    </definition>
    <definition id="var-between">
      <term>Variance Between Samples</term>
      <meaning id="mean-var-between">an estimate of the common population variance <m:math><m:msup><m:mi>σ</m:mi><m:mn>2</m:mn></m:msup></m:math> based on the variation among the sample means (the variance of the sample means multiplied by <m:math><m:mi>n</m:mi></m:math> when the sample sizes are equal); also called variation due to treatment or explained variation.</meaning>
    </definition>
    <definition id="var-within">
      <term>Variance Within Samples</term>
      <meaning id="mean-var-within">an estimate of the common population variance <m:math><m:msup><m:mi>σ</m:mi><m:mn>2</m:mn></m:msup></m:math> based on the average of the sample variances (a pooled variance); also called variation due to chance or unexplained variation.</meaning>
    </definition>
    <definition id="balanced-design">
      <term>Balanced Design</term>
      <meaning id="mean-balanced-design">an experimental design in which each factor level (group) has the same number of observations.</meaning>
    </definition>
  </glossary>

</document>
