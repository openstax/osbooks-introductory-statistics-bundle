<entry>73.5</entry>
<entry>94.1</entry>
<entry>64.7</entry>
<entry>64.7</entry>
</row>
<row>
<entry>70.6</entry>
<entry>38.2</entry>
<entry>61.8</entry>
<entry>88.2</entry>
<entry>70.6</entry>
<entry>58.8</entry>
<entry>91.2</entry>
<entry>73.5</entry>
<entry>82.4</entry>
<entry>35.5</entry>
</row>
<row>
<entry>94.1</entry>
<entry>88.2</entry>
<entry>64.7</entry>
<entry>55.9</entry>
<entry>88.2</entry>
<entry>97.1</entry>
<entry>85.3</entry>
<entry>61.8</entry>
<entry>79.4</entry>
<entry>79.4</entry>
</row>
</tbody>
</tgroup>
</table>
<table id="fs-idm124378288" summary="This table contains 30 final exam scores for the face-to-face class, arranged in three rows of ten values each.">
<title>Face-to-face Class</title>
<tgroup cols="10">
<colspec colnum="1" colname="c1"/>
<colspec colnum="2" colname="c2"/>
<colspec colnum="3" colname="c3"/>
<colspec colnum="4" colname="c4"/>
<colspec colnum="5" colname="c5"/>
<colspec colnum="6" colname="c6"/>
<colspec colnum="7" colname="c7"/>
<colspec colnum="8" colname="c8"/>
<colspec colnum="9" colname="c9"/>
<colspec colnum="10" colname="c10"/>
<tbody valign="top">
<row>
<entry>77.9</entry>
<entry>95.3</entry>
<entry>81.2</entry>
<entry>74.1</entry>
<entry>98.8</entry>
<entry>88.2</entry>
<entry>85.9</entry>
<entry>92.9</entry>
<entry>87.1</entry>
<entry>88.2</entry>
</row>
<row>
<entry>69.4</entry>
<entry>57.6</entry>
<entry>69.4</entry>
<entry>67.1</entry>
<entry>97.6</entry>
<entry>85.9</entry>
<entry>88.2</entry>
<entry>91.8</entry>
<entry>78.8</entry>
<entry>71.8</entry>
</row>
<row>
<entry>98.8</entry>
<entry>61.2</entry>
<entry>92.9</entry>
